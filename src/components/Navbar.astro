---
import ThemeToggle from './react/ThemeToggle';
import {
  SUPPORTED_LANGS,
  buildLanguageSwitchPath,
  getTranslations,
  localizeHashLink,
  localizePath,
  normalizeLang,
  type Lang,
} from '../lib/i18n';

interface Props {
  lang: string;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const activeLang = normalizeLang(lang);
const t = getTranslations(activeLang);

const navItems = [
  { key: 'home', href: localizeHashLink(activeLang, 'home'), label: t.nav.home },
  { key: 'mission', href: localizeHashLink(activeLang, 'mission'), label: t.nav.mission },
  { key: 'story', href: localizePath(activeLang, '/story'), label: t.nav.story },
  { key: 'milestones', href: localizeHashLink(activeLang, 'milestones'), label: t.nav.milestones },
  { key: 'transparency', href: localizeHashLink(activeLang, 'transparency'), label: t.nav.transparency },
];

const languageOptions = SUPPORTED_LANGS.map((optionLang) => ({
  value: buildLanguageSwitchPath(optionLang, currentPath),
  label: optionLang.toUpperCase(),
  selected: optionLang === activeLang,
}));
---
<!-- Navbar.astro - Secondary Navigation Bar -->

<nav class="sticky top-0 z-50 border-b border-theme-soft bg-theme-base-muted backdrop-blur-sm transition-colors duration-500">
  <div class="hidden items-center justify-between px-16 py-5 lg:flex">
    <ul class="flex gap-x-8">
      {navItems.map((item) => (
        <li>
          <a 
            href={item.href}
            class="font-sans text-sm uppercase tracking-widest text-theme-muted hover:text-brand-gold transition-colors duration-300 ease-in-out"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-x-6">
      <ThemeToggle client:load />

      <div class="relative">
        <label for="language-select" class="sr-only">{t.ui.selectLanguage}</label>
        <select
          id="language-select"
          class="font-sans text-sm uppercase tracking-widest text-theme-muted bg-transparent border border-theme rounded px-3 py-2 appearance-none pr-8 hover:border-brand-gold hover:text-brand-gold transition-colors duration-300 ease-in-out"
          onchange="if (this.value) window.location.href=this.value + window.location.hash"
        >
          {languageOptions.map((option) => (
            <option value={option.value} selected={option.selected}>{option.label}</option>
          ))}
        </select>
        <span class="pointer-events-none absolute inset-y-0 right-3 flex items-center text-theme-soft">▾</span>
      </div>
    </div>
  </div>

  <div class="px-4 py-4 sm:px-6 lg:hidden">
    <div class="flex items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <ThemeToggle client:load />

        <div class="relative">
          <label for="language-select-mobile" class="sr-only">{t.ui.selectLanguage}</label>
          <select
            id="language-select-mobile"
            class="font-sans text-sm uppercase tracking-widest text-theme-muted bg-transparent border border-theme rounded px-3 py-2 appearance-none pr-8 hover:border-brand-gold hover:text-brand-gold transition-colors duration-300 ease-in-out"
            onchange="if (this.value) window.location.href=this.value + window.location.hash"
          >
            {languageOptions.map((option) => (
              <option value={option.value} selected={option.selected}>{option.label}</option>
            ))}
          </select>
          <span class="pointer-events-none absolute inset-y-0 right-3 flex items-center text-theme-soft">▾</span>
        </div>
      </div>

      <details class="relative">
        <summary
          class="flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded border border-theme text-theme transition-colors duration-300 hover:border-brand-gold hover:text-brand-gold [&::-webkit-details-marker]:hidden"
          aria-label={t.ui.openNavigationMenu}
        >
          <span class="sr-only">{t.ui.openNavigationMenu}</span>
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <path d="M4 7h16" />
            <path d="M4 12h16" />
            <path d="M4 17h16" />
          </svg>
        </summary>

        <div class="absolute right-0 top-[calc(100%+0.75rem)] w-56 rounded-xl border border-theme-strong bg-theme-base px-4 py-4 text-theme shadow-[0_18px_50px_rgba(0,0,0,0.12)]">
          <ul class="flex flex-col gap-3">
            {navItems.map((item) => (
              <li>
                <a 
                  href={item.href}
                  class="block font-sans text-sm uppercase tracking-widest text-theme-muted hover:text-brand-gold transition-colors duration-300 ease-in-out"
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </details>
    </div>
  </div>
</nav>
