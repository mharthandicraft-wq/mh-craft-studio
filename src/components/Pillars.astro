---
// src/components/Pillars.astro
---

<section class="w-full py-24 px-6 md:px-12 bg-brand-dark">
  <div class="max-w-[1920px] mx-auto">
    
    <div class="max-w-3xl mx-auto text-center mb-20">
      <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl text-white mb-6 tracking-tight">
        The Three Pillars of Our Work
      </h2>
      <p class="font-sans text-neutral-400 text-lg md:text-xl leading-relaxed">
        Our vision is to combine traditional craftsmanship with modern digital tools to create a sustainable creative ecosystem.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 max-w-6xl mx-auto">
      
      <div class="group relative border border-white/10 bg-white/[0.02] p-10 transition-all duration-500 hover:border-brand-gold hover:bg-white/[0.04] rounded-lg">
        <div class="mb-8 text-neutral-500 transition-colors duration-500 group-hover:text-brand-gold">
          <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
        </div>
        <h3 class="font-serif text-2xl text-brand-gold mb-4">Preservation</h3>
        <p class="font-sans text-neutral-400 leading-relaxed text-sm">
          Keeping endangered traditional craftsmanship techniques alive.
        </p>
      </div>

      <div class="group relative border border-white/10 bg-white/[0.02] p-10 transition-all duration-500 hover:border-brand-gold hover:bg-white/[0.04] rounded-lg">
        <div class="mb-8 text-neutral-500 transition-colors duration-500 group-hover:text-brand-gold">
          <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 2l3 6 6 1-4 4 1 6-6-3-6 3 1-6-4-4 6-1 3-6z"/>
          </svg>
        </div>
        <h3 class="font-serif text-2xl text-brand-gold mb-4">Empowerment</h3>
        <p class="font-sans text-neutral-400 leading-relaxed text-sm">
          Providing training and creating employment opportunities for refugee communities.
        </p>
      </div>

      <div class="group relative border border-white/10 bg-white/[0.02] p-10 transition-all duration-500 hover:border-brand-gold hover:bg-white/[0.04] rounded-lg">
        <div class="mb-8 text-neutral-500 transition-colors duration-500 group-hover:text-brand-gold">
          <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10" stroke-width="1"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
        </div>
        <h3 class="font-serif text-2xl text-brand-gold mb-4">Global Reach</h3>
        <p class="font-sans text-neutral-400 leading-relaxed text-sm">
          Exporting authentic art worldwide through digital marketing.
        </p>
      </div>

    </div>
  </div>
</section>