---
import { getTranslations, localizeHashLink, normalizeLang } from '../lib/i18n';

interface Props {
  lang: string;
}

const currentYear = new Date().getFullYear();
const { lang } = Astro.props;
const activeLang = normalizeLang(lang);
const t = getTranslations(activeLang);
---

<footer class="bg-theme-base border-t border-theme-soft pt-20 pb-10 px-6 md:px-12 transition-colors duration-500">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      
      <div class="space-y-6">
        <h3 class="font-serif text-2xl text-theme">Khatam <span class="text-brand-gold italic">Art</span></h3>
        <p class="font-sans text-theme-muted text-sm leading-relaxed">
          {t.footer.tagline}
        </p>
        <div class="flex gap-4">
          <a href="https://www.linkedin.com/in/mohammad-hedayat-a4b304334/" target="_blank" rel="noopener noreferrer" class="text-neutral-500 hover:text-brand-gold transition-colors" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </a>
          <a href="https://youtube.com/@mh.art.handicraft2474?si=-CmrD9FYgw19zzC6" target="_blank" rel="noopener noreferrer" class="text-neutral-500 hover:text-brand-gold transition-colors" aria-label="YouTube">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
          <a href="https://www.instagram.com/mh.art.handicraft/" target="_blank" rel="noopener noreferrer" class="text-neutral-500 hover:text-brand-gold transition-colors" aria-label="Instagram">
             <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
        </div>
      </div>

      <div class="space-y-6">
        <h4 class="font-sans text-xs uppercase tracking-[0.2em] text-theme font-bold">{t.footer.contact}</h4>
        <ul class="space-y-4 font-sans text-sm text-theme-muted">
          <li><a href="mailto:mh.art.handicraft@gmail.com" class="hover:text-brand-gold transition-colors underline decoration-[var(--color-border-strong)] underline-offset-4">mh.art.handicraft@gmail.com</a></li>
          <li><a href="tel:+905511085625" class="hover:text-brand-gold transition-colors">+90 551 108 56 25</a></li>
          <li><a href="https://wa.me/905511085625" target="_blank" rel="noopener noreferrer" class="hover:text-brand-gold transition-colors">WhatsApp: +90 551 108 56 25</a></li>
        </ul>
      </div>

      <div class="space-y-6">
        <h4 class="font-sans text-xs uppercase tracking-[0.2em] text-theme font-bold">{t.footer.credentials}</h4>
        <a href="https://coursera.org/share/36d376f90bc10e5666402d7d9ae53e31" target="_blank" rel="noopener noreferrer" class="flex items-start gap-3 group bg-theme-surface p-4 border border-theme-soft rounded-sm hover:border-brand-gold/40 transition-colors">
           <div class="w-8 h-8 bg-blue-500/10 rounded flex items-center justify-center shrink-0 overflow-hidden">
             <img src="/images/google-ux-certificate-logo.svg" alt="Google UX Design Certificate logo" class="w-6 h-6" />
          </div>
          <p class="font-sans text-xs text-theme-muted leading-tight">
            Google Professional <br/> <span class="text-theme">UX Design Certificate</span>
          </p>
        </a>
      </div>

      <div class="space-y-6">
        <h4 class="font-sans text-xs uppercase tracking-[0.2em] text-theme font-bold">{t.footer.resources}</h4>
        <ul class="space-y-3 font-sans text-sm text-theme-muted">
          <li><a href={localizeHashLink(activeLang, 'transparency')} class="hover:text-brand-gold transition-colors">{t.ui.transparencyLog}</a></li>
          <li><a href="/proposal.pdf" class="hover:text-brand-gold transition-colors">{t.ui.proposalPdf}</a></li>
          <li><a href={localizeHashLink(activeLang, 'support')} class="text-brand-gold hover:underline underline-offset-4">{t.ui.supportTheProject}</a></li>
        </ul>
      </div>

    </div>

    <div class="pt-8 border-t border-theme-soft flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="font-sans text-[10px] uppercase tracking-widest text-theme-muted">
        © {currentYear} {t.footer.rights}
      </p>
      <p class="font-sans text-[10px] uppercase tracking-widest text-theme-muted">
        {t.footer.location}
      </p>
    </div>
  </div>
</footer>