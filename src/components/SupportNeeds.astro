---
/* Section focused on clear, actionable support requests */
interface Props {
  content: {
    eyebrow: string;
    title: string;
    accent: string;
    quote: string;
    items: Array<{
      id: string;
      title: string;
      description: string;
    }>;
    buttons?: Array<{
      label: string;
      href: string;
      variant: 'primary' | 'secondary' | 'outline';
    }>;
  };
}

const { content } = Astro.props;
---

<section class="w-full py-32 px-6 md:px-12 bg-theme-base">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
      
      {/* Left Column: Title & Intent */}
      <div class="lg:col-span-5">
        <span class="text-brand-gold font-sans text-xs uppercase tracking-[0.3em] mb-6 block font-semibold">
          {content.eyebrow}
        </span>
        <h2 class="font-serif text-4xl md:text-5xl text-theme mb-8 leading-tight">
          {content.title} <br /> <span class="text-brand-gold italic">{content.accent}</span>
        </h2>
        <div class="p-6 bg-theme-surface border-l-2 border-brand-gold/50">
          <p class="font-sans text-theme-soft text-lg leading-relaxed italic">
            "{content.quote}"
          </p>
        </div>

        {content.buttons && content.buttons.length > 0 && (
          <div class="flex flex-col gap-4 mt-10">
            {content.buttons.map((btn) => (
              btn.variant === 'primary' ? (
                <a
                  href={btn.href}
                  class="w-full px-8 py-4 bg-brand-gold text-theme-contrast font-sans font-bold uppercase tracking-widest text-sm text-center hover:brightness-105 transition-all duration-300 rounded-sm"
                >
                  {btn.label}
                </a>
              ) : btn.variant === 'secondary' ? (
                <a
                  href={btn.href}
                  class="w-full px-8 py-4 border border-theme text-theme font-sans font-bold uppercase tracking-widest text-sm text-center hover:border-brand-gold/70 hover:text-brand-gold transition-all duration-300 rounded-sm"
                >
                  {btn.label}
                </a>
              ) : (
                <a
                  href={btn.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-full px-8 py-4 border border-theme text-theme font-sans font-bold uppercase tracking-widest text-sm text-center hover:bg-theme-surface transition-all duration-300 rounded-sm"
                >
                  {btn.label}
                </a>
              )
            ))}
          </div>
        )}
      </div>

      {/* Right Column: Specific Needs */}
      <div class="lg:col-span-7 grid grid-cols-1 gap-6">
        {content.items.map((item) => (
          <div class="p-8 border theme-card theme-card-hover rounded-lg group hover:border-brand-gold/30 transition-all duration-500">
            <div class="flex items-start gap-6">
              <span class="font-serif text-3xl text-brand-gold/30 group-hover:text-brand-gold transition-colors italic">{item.id}</span>
              <div>
                <h3 class="font-serif text-2xl text-theme mb-3">{item.title}</h3>
                <p class="font-sans text-theme-muted leading-relaxed">
                  {item.description}
                </p>
              </div>
            </div>
          </div>
        ))}

      </div>
    </div>
  </div>
</section>