---
import { getTranslations, localizePath, normalizeLang } from '../lib/i18n';

interface Props {
  lang: string;
  content: {
    eyebrow: string;
    title: string;
    intro: string;
    quote: string;
    items: string[];
  };
}

const { lang, content } = Astro.props;
const activeLang = normalizeLang(lang);
const t = getTranslations(activeLang);
---

<section class="w-full py-10 md:py-32 px-6 md:px-12 bg-theme-base relative overflow-hidden flex items-center min-h-screen transition-colors duration-500">
  
  <div class="absolute right-[-50%] md:right-[-10%] top-1/2 -translate-y-1/2 w-[600px] md:w-[600px] h-[600px] md:h-[600px] opacity-[0.1] pointer-events-none animate-[spin_120s_linear_infinite]">
    <div class="absolute inset-0 border border-theme rotate-0"></div>
    <div class="absolute inset-0 border border-theme rotate-45"></div>
    <div class="absolute inset-12 border border-theme rotate-[22.5deg]"></div>
    <div class="absolute inset-12 border border-theme -rotate-[22.5deg]"></div>
    <div class="absolute inset-32 border-2 border-brand-gold rotate-45"></div>
    <div class="absolute inset-48 border border-brand-gold rotate-0"></div>
  </div>

  <div class="max-w-6xl mx-auto w-full grid grid-cols-1 lg:grid-cols-12 gap-16 relative z-10">
    
    <div class="lg:col-span-5 flex flex-col justify-center">
      <span class="text-brand-gold font-sans text-xs uppercase tracking-[0.2em] mb-4 block font-semibold">
        {content.eyebrow}
      </span>
      <h2 class="font-serif text-4xl md:text-5xl text-theme mb-6 leading-tight">
        {content.title}
      </h2>
      <p class="font-sans text-theme-soft text-lg leading-relaxed mb-16">
        {content.intro}
      </p>

      <div class="pl-6 border-l-2 border-brand-gold/50 relative">
        <div class="absolute -left-[5px] top-0 w-2 h-2 bg-brand-gold rotate-45"></div>
        <p class="font-serif text-2xl md:text-3xl text-theme italic leading-snug">
          "{content.quote}"
        </p>
      </div>

      <a href={localizePath(activeLang, '/story')} class="mt-10 inline-flex items-center gap-4 text-brand-gold font-sans text-sm uppercase tracking-[0.2em] group border-b border-brand-gold/30 pb-2 hover:text-theme hover:border-theme transition-all">
        {t.ui.readOurStory}
        <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <div class="lg:col-span-7 flex flex-col gap-4 lg:pl-12">
      {content.items.map((item) => (
        <div class="flex items-start gap-6 group theme-card border p-6 rounded-lg hover:border-brand-gold/30 transition-all duration-500 theme-card-hover">
          <div class="mt-1.5 w-2.5 h-2.5 bg-brand-gold rotate-45 shrink-0 group-hover:rotate-90 group-hover:scale-125 transition-all duration-500"></div>
          <p class="font-sans text-theme-soft text-base md:text-lg leading-relaxed">
            {item}
          </p>
        </div>
      ))}

    </div>
  </div>
</section>