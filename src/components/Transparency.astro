---
/* Transparency section with a documentary and trust-focused design */
---

<section class="w-full py-32 px-6 md:px-12 bg-brand-dark border-t border-white/5 relative overflow-hidden">
  
  <div class="max-w-6xl mx-auto relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
      <div class="lg:col-span-7 bg-white/[0.01] border border-white/10 rounded-lg p-8 md:p-12 relative">
        <div class="absolute top-0 right-0 p-4 opacity-10">
            <svg class="w-24 h-24 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
        </div>

        <div class="space-y-10">
          {[
            { title: "Sharing updates on progress", desc: "Regular milestones shared with our supporters." },
            { title: "Documenting workshop development", desc: "Step-by-step visual reports on the new space." },
            { title: "Showing real production & process", desc: "Behind-the-scenes look at the craftsmanship." },
            { title: "Financial Transparency", desc: "Clear reporting on how every grant or donation is used." }
          ].map((item) => (
            <div class="flex items-start gap-6 group">
              <div class="w-6 h-6 rounded-full border border-brand-gold/50 flex items-center justify-center shrink-0 mt-1 group-hover:bg-brand-gold transition-all duration-500">
                <svg class="w-3 h-3 text-brand-gold group-hover:text-brand-dark" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-serif text-xl text-white mb-2">{item.title}</h3>
                <p class="font-sans text-neutral-500 text-sm leading-relaxed">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="lg:col-span-5">
        <span class="text-brand-gold font-sans text-xs uppercase tracking-[0.3em] mb-6 block font-semibold">
          Transparency
        </span>
        <h2 class="font-serif text-4xl md:text-5xl text-white mb-8 leading-tight">
          Commitment to <br /> <span class="text-brand-gold italic">Openness</span>
        </h2>
        <p class="font-sans text-neutral-400 text-lg leading-relaxed max-w-md mb-8">
          We understand that trust is built through clarity. It is our responsibility to show exactly how your support translates into real-world craft preservation.
        </p>
        
        <a href="/transparency" class="inline-flex items-center gap-4 text-brand-gold font-sans text-sm uppercase tracking-[0.2em] group border-b border-brand-gold/30 pb-2 hover:text-white hover:border-white transition-all">
          View Transparency Page
          <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      

    </div>
  </div>
</section>