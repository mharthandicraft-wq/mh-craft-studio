---
/* Transparency section with a documentary and trust-focused design */

interface Props {
  lang?: string;
  content: {
    eyebrow: string;
    title: string;
    accent: string;
    description: string;
    items: Array<{
      title: string;
      description: string;
    }>;
  };
}

const { content } = Astro.props;
---

<section class="w-full py-20 md:py-32 px-6 md:px-12 bg-theme-base  relative overflow-hidden transition-colors duration-500">
  
  <div class="max-w-6xl mx-auto relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
        <div class="order-2 lg:order-1 lg:col-span-7 theme-card border rounded-lg p-8 md:p-12 relative">
        <div class="absolute top-0 right-0 p-4 opacity-10">
          <svg class="w-24 h-24 text-theme" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
        </div>

        <div class="space-y-10">
          {content.items.map((item) => (
            <div class="flex items-start gap-6 group">
              <div class="w-6 h-6 rounded-full border border-brand-gold/50 flex items-center justify-center shrink-0 mt-1 group-hover:bg-brand-gold transition-all duration-500">
                <svg class="w-3 h-3 text-brand-gold group-hover:text-brand-dark" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-serif text-xl text-theme mb-2">{item.title}</h3>
                <p class="font-sans text-theme-muted text-sm leading-relaxed">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="order-1 lg:order-2 lg:col-span-5">
        <span class="text-brand-gold font-sans text-xs uppercase tracking-[0.3em] mb-6 block font-semibold">
          {content.eyebrow}
        </span>
        <h2 class="font-serif text-4xl md:text-5xl text-theme mb-8 leading-tight">
          {content.title} <br /> <span class="text-brand-gold italic">{content.accent}</span>
        </h2>
        <p class="font-sans text-theme-muted text-lg leading-relaxed max-w-md mb-8">
          {content.description}
        </p>
        
      </div>

      

    </div>
  </div>
</section>