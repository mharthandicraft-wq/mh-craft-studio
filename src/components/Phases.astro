---
// src/components/Phases.astro
---

<section class="w-full py-24 px-6 md:px-12 bg-brand-light dark:bg-brand-dark relative overflow-hidden">
  <div class="max-w-6xl mx-auto">
    
    <div class="text-center mb-24">
      <h2 class="font-serif text-4xl md:text-5xl text-brand-accent dark:text-white mb-6">
        How This Would Grow
      </h2>
      <div class="w-16 h-[1px] bg-brand-gold/50 mx-auto"></div>
    </div>

    <div class="relative max-w-5xl mx-auto border border-white/5 bg-white/[0.01] rounded-lg overflow-hidden">
      
      <div class="hidden md:flex absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-10 h-10 border border-brand-gold/20 bg-brand-dark rotate-45 z-10 items-center justify-center transition-all duration-700 hover:border-brand-gold hover:rotate-90">
        <div class="w-2.5 h-2.5 bg-brand-gold"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2">
        
        <div class="group border-b md:border-b md:border-r border-white/5 p-10 md:p-16 transition-all duration-500 hover:bg-white/[0.02]">
          <div class="mb-8">
            <span class="text-white font-sans text-xs uppercase tracking-[0.2em] mb-2 block font-semibold">
              Phase 01 (Months 1–2)
            </span>
            <h3 class="font-serif text-3xl text-brand-gold">Setup</h3>
          </div>
          <ul class="space-y-4">
            <li class="flex items-start gap-4 text-neutral-300 font-sans text-sm md:text-base leading-relaxed">
              <span class="mt-2 w-1.5 h-1.5 bg-white/10 rounded-full shrink-0 group-hover:bg-brand-gold transition-colors duration-500"></span>
              Secure a small workshop space
            </li>
            <li class="flex items-start gap-4 text-neutral-300 font-sans text-sm md:text-base leading-relaxed">
              <span class="mt-2 w-1.5 h-1.5 bg-white/10 rounded-full shrink-0 group-hover:bg-brand-gold transition-colors duration-500"></span>
              Acquire essential tools and materials
            </li>
            <li class="flex items-start gap-4 text-neutral-300 font-sans text-sm md:text-base leading-relaxed">
              <span class="mt-2 w-1.5 h-1.5 bg-white/10 rounded-full shrink-0 group-hover:bg-brand-gold transition-colors duration-500"></span>
              Reorganize a stable working environment
            </li>
          </ul>
        </div>

        <div class="group border-b border-white/5 p-10 md:p-16 transition-all duration-500 hover:bg-white/[0.02]">
          <div class="mb-8">
            <span class="text-white font-sans text-xs uppercase tracking-[0.2em] mb-2 block font-semibold">
              Phase 02 (Months 3–4)
            </span>
            <h3 class="font-serif text-3xl text-brand-gold">Restart</h3>
          </div>
          <ul class="space-y-4">
            <li class="flex items-start gap-4 text-neutral-300 font-sans text-sm md:text-base leading-relaxed">
              <span class="mt-2 w-1.5 h-1.5 bg-white/10 rounded-full shrink-0 group-hover:bg-brand-gold transition-colors duration-500"></span>
              Begin small-scale production again
            </li>
            <li class="flex items-start gap-4 text-neutral-300 font-sans text-sm md:text-base leading-relaxed">
              <span class="mt-2 w-1.5 h-1.5 bg-white/10 rounded-full shrink-0 group-hover:bg-brand-gold transition-colors duration-500"></span>
              Focus on quality and consistency
            </li>
            <li class="flex items-start gap-4 text-neutral-300 font-sans text-sm md:text-base leading-relaxed">
              <span class="mt-2 w-1.5 h-1.5 bg-white/10 rounded-full shrink-0 group-hover:bg-brand-gold transition-colors duration-500"></span>
              Rebuild working rhythm
            </li>
          </ul>
        </div>

        <div class="group border-b md:border-b-0 md:border-r border-white/5 p-10 md:p-16 transition-all duration-500 hover:bg-white/[0.02]">
          <div class="mb-8">
            <span class="text-white font-sans text-xs uppercase tracking-[0.2em] mb-2 block font-semibold">
              Phase 03 (Months 5–6)
            </span>
            <h3 class="font-serif text-3xl text-brand-gold">Sharing</h3>
          </div>
          <ul class="space-y-4">
            <li class="flex items-start gap-4 text-neutral-300 font-sans text-sm md:text-base leading-relaxed">
              <span class="mt-2 w-1.5 h-1.5 bg-white/10 rounded-full shrink-0 group-hover:bg-brand-gold transition-colors duration-500"></span>
              Begin sharing skills with a very small group of learners
            </li>
            <li class="flex items-start gap-4 text-neutral-300 font-sans text-sm md:text-base leading-relaxed">
              <span class="mt-2 w-1.5 h-1.5 bg-white/10 rounded-full shrink-0 group-hover:bg-brand-gold transition-colors duration-500"></span>
              Document the process for transparency and education
            </li>
          </ul>
        </div>

        <div class="group p-10 md:p-16 transition-all duration-500 hover:bg-white/[0.02]">
          <div class="mb-8">
            <span class="text-white font-sans text-xs uppercase tracking-[0.2em] mb-2 block font-semibold">
              Phase 04 (6+ Months)
            </span>
            <h3 class="font-serif text-3xl text-brand-gold">Continuity</h3>
          </div>
          <ul class="space-y-4">
            <li class="flex items-start gap-4 text-neutral-300 font-sans text-sm md:text-base leading-relaxed">
              <span class="mt-2 w-1.5 h-1.5 bg-white/10 rounded-full shrink-0 group-hover:bg-brand-gold transition-colors duration-500"></span>
              Gradual growth based on capacity
            </li>
            <li class="flex items-start gap-4 text-neutral-300 font-sans text-sm md:text-base leading-relaxed">
              <span class="mt-2 w-1.5 h-1.5 bg-white/10 rounded-full shrink-0 group-hover:bg-brand-gold transition-colors duration-500"></span>
              Expansion only if stability is achieved
            </li>
          </ul>
        </div>

      </div>
    </div>
  </div>
</section>