---
interface Props {
  content: {
    title: string;
    items: Array<{
      label: string;
      title: string;
      steps: string[];
    }>;
  };
}

const { content } = Astro.props;
---

<section class="w-full py-10 md:py-32 px-6 md:px-12 bg-theme-base relative overflow-hidden transition-colors duration-500">
  <div class="max-w-6xl mx-auto">
    
    <div class="text-center mb-10">
      <h2 class="font-serif text-4xl md:text-5xl text-theme mb-6">
        {content.title}
      </h2>
      
    </div>

    <div class="relative max-w-5xl mx-auto border theme-card rounded-lg overflow-hidden">
      
      <div class="hidden md:flex absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-10 h-10 border border-brand-gold/20 bg-theme-base rotate-45 z-10 items-center justify-center transition-all duration-700 hover:border-brand-gold hover:rotate-90">
        <div class="w-2.5 h-2.5 bg-brand-gold"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2">
        {content.items.map((phase, index) => (
          <div class={`group ${index < 2 ? 'border-b' : ''} ${index % 2 === 0 ? 'md:border-r' : ''} ${index === 2 ? 'md:border-b-0' : ''} border-theme-soft p-10 md:p-16 transition-all duration-500 hover:bg-theme-surface-strong`}>
            <div class="mb-8">
              <span class="text-theme font-sans text-xs uppercase tracking-[0.2em] mb-2 block font-semibold">
                {phase.label}
              </span>
              <h3 class="font-serif text-3xl text-brand-gold">{phase.title}</h3>
            </div>
            <ul class="space-y-4">
              {phase.steps.map((step) => (
                <li class="flex items-start gap-4 text-theme-soft font-sans text-sm md:text-base leading-relaxed">
                  <span class="mt-2 w-1.5 h-1.5 bg-theme-dot rounded-full shrink-0 group-hover:bg-brand-gold transition-colors duration-500"></span>
                  {step}
                </li>
              ))}
            </ul>
          </div>
        ))}

      </div>
    </div>
  </div>
</section>