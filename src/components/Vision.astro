---
interface Props {
  content: {
    title: string;
    paragraphs: string[];
    goals: string[];
  };
}

const { content } = Astro.props;
---

<section class="w-full py-10 md:py-32 px-6 md:px-12 bg-theme-base transition-colors duration-500">

  <div class="max-w-6xl mx-auto text-left md:text-center mb-16">
    <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl text-theme mb-8 leading-tight">
      {content.title}
    </h2>
  </div>
  
  <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
    
    
    <div class="lg:sticky lg:top-32">
      
      
      <div class="space-y-6">
        {content.paragraphs.map((paragraph) => (
          <p class="font-sans text-theme-soft text-lg leading-relaxed">
            {paragraph}
          </p>
        ))}
      </div>
    </div>
    <div class="flex flex-col gap-10 lg:pt-4">
      {content.goals.map((goal, index) => (
        <div class="border-b border-theme pb-8">
          <div class="text-brand-gold font-serif text-xl mb-2">{String(index + 1).padStart(2, '0')}.</div>
          <h3 class="font-serif text-3xl text-theme tracking-wide">
            {goal}
          </h3>
        </div>
      ))}

    </div>

  </div>
</section>