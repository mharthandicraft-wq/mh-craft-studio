---
import { DEFAULT_LANG, SUPPORTED_LANGS } from '../lib/i18n';

const fallbackPath = `/${DEFAULT_LANG}`;
---

<script is:inline define:vars={{ fallbackPath, supportedLangs: SUPPORTED_LANGS }}>
	const preferredLanguages = Array.isArray(navigator.languages) && navigator.languages.length > 0
		? navigator.languages
		: [navigator.language];

	const matchedLanguage = preferredLanguages
		.map((language) => String(language).toLowerCase().split('-')[0])
		.find((language) => supportedLangs.includes(language));

	window.location.replace(matchedLanguage ? `/${matchedLanguage}` : fallbackPath);
</script>

<noscript>
	<meta http-equiv="refresh" content={`0;url=${fallbackPath}`} />
</noscript>