---
import MainLayout from '../../layouts/MainLayout.astro';
import { getStoryPageContent } from '../../lib/content';
import { SUPPORTED_LANGS, normalizeLang } from '../../lib/i18n';

export function getStaticPaths() {
  return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}

const activeLang = normalizeLang(Astro.params.lang);
const content = await getStoryPageContent(activeLang);
---

<MainLayout
  title={content.meta.title}
  description={content.meta.description}
  lang={activeLang}
>
  <!-- ─── Hero / Title ─── -->
  <section class="relative overflow-hidden pb-16 pt-24 sm:pb-20 sm:pt-32 lg:pb-24 lg:pt-40">
    <!-- Ambient gold blobs -->
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute -top-40 start-0 h-[36rem] w-[36rem] bg-[radial-gradient(circle,rgba(197,160,89,0.18)_0%,transparent_65%)] blur-3xl"></div>
      <div class="absolute bottom-0 end-0 h-72 w-72 bg-[radial-gradient(circle,rgba(197,160,89,0.10)_0%,transparent_65%)] blur-2xl"></div>
    </div>

    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <p class="mb-6 font-sans text-xs uppercase tracking-[0.38em] text-brand-gold">
        {content.hero.eyebrow}
      </p>
      <h1 class="font-serif text-5xl leading-[1.08] text-theme sm:text-6xl lg:text-7xl xl:text-[5.5rem]">
        {content.hero.title}
        <em class="block not-italic text-brand-gold">{content.hero.highlight}</em>
      </h1>
      <!-- Decorative rule -->
      <div class="mt-10 h-px w-20 bg-brand-gold/50"></div>
    </div>
  </section>

  <!-- ─── Three alternating two-column sections ─── -->
  {content.sections.map((section, index) => {
    const imageOnLeft = index % 2 === 0;
    return (
      <section
        class:list={[
          'py-16 sm:py-20 lg:py-28',
          index === 1 && 'bg-theme-panel',
        ]}
      >
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16 xl:gap-24">

            <!-- Image -->
            <figure
              class:list={[
                'overflow-hidden rounded-sm',
                !imageOnLeft && 'lg:order-last',
              ]}
            >
              <img
                src={section.image.src}
                alt={section.image.alt}
                loading="lazy"
                class="aspect-[11/16] w-full object-cover"
              />
            </figure>

            <!-- Text -->
            <article class="space-y-6">
              <h2 class="font-serif text-3xl leading-tight text-theme sm:text-4xl lg:text-[2.5rem]">
                {section.title}
              </h2>
              <div class="space-y-5 text-base leading-loose text-theme-soft sm:text-[1.05rem]">
                {section.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
              </div>
            </article>

          </div>
        </div>
      </section>
    );
  })}

  <section class="pb-20 pt-6 sm:pb-24 lg:pb-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-4 sm:gap-5 lg:grid-cols-2 lg:gap-6">
        <a
          href="#"
          class="inline-flex w-full items-center justify-center rounded-sm bg-brand-gold px-6 py-4 text-center font-sans text-sm font-semibold uppercase tracking-[0.16em] text-[#111111] transition hover:brightness-95"
        >
          Support Project
        </a>
        <a
          href="#"
          class="inline-flex w-full items-center justify-center rounded-sm border border-theme-strong bg-theme-panel px-6 py-4 text-center font-sans text-sm font-semibold uppercase tracking-[0.16em] text-theme transition hover:border-brand-gold/70 hover:text-brand-gold"
        >
          Support Us With Buy Me a Coffee
        </a>
      </div>
    </div>
  </section>
</MainLayout>
