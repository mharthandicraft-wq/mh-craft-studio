---
import MainLayout from '../../layouts/MainLayout.astro';
import { getOrganizationSupporterPageContent } from '../../lib/content';
import { SUPPORTED_LANGS, normalizeLang } from '../../lib/i18n';

export function getStaticPaths() {
  return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}

const activeLang = normalizeLang(Astro.params.lang);
const content = await getOrganizationSupporterPageContent(activeLang);
const proposalOpensInNewTab = /^https?:\/\//.test(content.proposalCtaHref);
const finalPrimaryOpensInNewTab = /^https?:\/\//.test(content.finalCta.primaryHref);
---

<MainLayout title={content.meta.title} description={content.meta.description} lang={activeLang}>

  <!-- ═══════════════════════════════════════════════════════════════
       SECTION 1 — HERO  (Experience.astro + HeroScroll pattern)
       5/7 split · geometric decoration · image placeholder
       ═══════════════════════════════════════════════════════════════ -->
  <section class="w-full bg-theme-base relative overflow-hidden transition-colors duration-500 py-10 md:py-32 px-6 md:px-12 flex items-center min-h-screen">

    <!-- Geometric decoration — spinning nested squares -->
    <div class="absolute end-[-50%] md:end-[-10%] top-1/2 -translate-y-1/2 w-[600px] h-[600px] opacity-[0.08] pointer-events-none animate-[spin_120s_linear_infinite]" aria-hidden="true">
      <div class="absolute inset-0 border border-theme rotate-0"></div>
      <div class="absolute inset-0 border border-theme rotate-45"></div>
      <div class="absolute inset-12 border border-theme rotate-[22.5deg]"></div>
      <div class="absolute inset-12 border border-theme -rotate-[22.5deg]"></div>
      <div class="absolute inset-32 border-2 border-brand-gold rotate-45"></div>
      <div class="absolute inset-48 border border-brand-gold rotate-0"></div>
    </div>

    <!-- Radial glow accents -->
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute -top-36 start-0 h-[32rem] w-[32rem] bg-[radial-gradient(circle,rgba(197,160,89,0.16)_0%,transparent_65%)] blur-3xl"></div>
      <div class="absolute bottom-0 end-0 h-72 w-72 bg-[radial-gradient(circle,rgba(197,160,89,0.1)_0%,transparent_65%)] blur-2xl"></div>
    </div>

    <div class="max-w-6xl mx-auto w-full relative z-10 flex flex-col gap-10 lg:gap-12">

      <!-- Row 1 -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">

        <!-- Left column — Hero image -->
        <div class="flex items-center">
          <div class="w-full h-[42vh] md:h-[50vh] lg:h-[60vh] rounded-lg border border-brand-gold/20 bg-theme-surface relative overflow-hidden">
            <img
              src="/images/organization-support-page/persian-khatam-marquetry-handmade-backgommon-chess-board.webp"
              alt="Persian khatam marquetry handmade backgammon chess board"
              class="w-full h-full object-cover"
              loading="eager"
              decoding="async"
            />
          </div>
        </div>

        <!-- Right column — Hero text -->
        <div class="flex flex-col justify-center">
          <span class="text-brand-gold font-sans text-xs uppercase tracking-[0.3em] mb-6 block font-semibold">
            {content.eyebrow}
          </span>

          <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl text-theme leading-tight mb-6">
            {content.title}
          </h1>

          <p class="font-sans text-theme-soft text-lg leading-relaxed mb-4">
            {content.subtitle}
          </p>

          <p class="font-sans text-theme-muted text-base leading-relaxed">
            {content.shortLine}
          </p>
        </div>
      </div>

      <!-- Row 2 -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 mt-24">

        <!-- Left box — Where Your Support Can Help -->
        <div class="group border theme-card p-8 rounded-lg theme-card-hover hover:border-brand-gold/30 transition-all duration-500 flex h-full flex-col">
          <h2 class="font-serif text-2xl text-brand-gold mb-4">{content.sections[0].title}</h2>
          <ul class="flex-1 space-y-4" aria-label={content.sections[0].title}>
            {content.sections[0].items.map((item) => (
              <li class="flex items-start gap-4 text-start font-sans text-theme-soft text-base leading-relaxed">
                <span class="mt-2 w-2 h-2 bg-brand-gold rotate-45 shrink-0 group-hover:rotate-90 group-hover:scale-125 transition-all duration-500" aria-hidden="true"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>

          <a
            href={content.proposalCtaHref}
            target={proposalOpensInNewTab ? '_blank' : undefined}
            rel={proposalOpensInNewTab ? 'noopener noreferrer' : undefined}
            class="mt-8 w-full px-8 py-4 bg-brand-gold text-theme-contrast font-sans font-bold uppercase tracking-widest text-sm text-center hover:brightness-105 transition-all duration-300 rounded-sm"
          >
            {content.proposalCtaLabel}
          </a>
        </div>

        <!-- Right box — How We Collaborate -->
        <div class="group border theme-card p-8 rounded-lg theme-card-hover hover:border-brand-gold/30 transition-all duration-500 flex h-full flex-col">
          <h2 class="font-serif text-2xl text-brand-gold mb-4">{content.sections[1].title}</h2>
          <ul class="flex-1 space-y-4" aria-label={content.sections[1].title}>
            {content.sections[1].items.map((item) => (
              <li class="flex items-start gap-4 text-start font-sans text-theme-soft text-base leading-relaxed">
                <span class="mt-2 w-2 h-2 bg-brand-gold rotate-45 shrink-0 group-hover:rotate-90 group-hover:scale-125 transition-all duration-500" aria-hidden="true"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>

          <a
            href={content.partnerCtaHref}
            class="mt-8 w-full px-8 py-4 bg-brand-gold text-theme-contrast font-sans font-bold uppercase tracking-widest text-sm text-center hover:brightness-105 transition-all duration-300 rounded-sm"
          >
            {content.partnerCtaLabel}
          </a>
        </div>
      </div>

    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       SECTION 2 — PROJECT OVERVIEW  (Vision.astro pattern)
       Sticky left sidebar · zero-padded numbered goals · image placeholder
       ═══════════════════════════════════════════════════════════════ -->
  <section class="w-full py-10 md:py-22 px-6 md:px-12 bg-theme-base transition-colors duration-500">
    <div class="max-w-6xl mx-auto">
      <div class="max-w-3xl mx-auto text-center lg:text-start mb-16">
        <span class="text-brand-gold font-sans text-xs uppercase tracking-[0.3em] mb-6 block font-semibold">
          {content.projectOverview.eyebrow}
        </span>
        <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl text-theme leading-tight">
          {content.projectOverview.title}
        </h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">
        <!-- Left — Sticky intro + image -->
        <div class="lg:sticky lg:top-32">
          <p class="font-sans text-theme-soft text-lg leading-relaxed mb-10">
            {content.projectOverview.intro}
          </p>

          <!-- Workshop image -->
          <div class="w-full rounded-lg border border-brand-gold/20 bg-theme-surface relative overflow-hidden">
            <img
              src="/images/organization-support-page/persian-khatam-marquetry-handmade-backgommon.webp"
              alt="Persian khatam marquetry handmade backgammon"
              class="block w-full h-auto"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>

        <!-- Right — Numbered goal items -->
        <div class="flex flex-col gap-10 lg:pt-4">
          {content.projectOverview.items.map((item, index) => (
            <div class="border-b border-theme pb-8">
              <div class="text-brand-gold font-serif text-xl mb-2">{String(index + 1).padStart(2, '0')}.</div>
              <h3 class="font-serif text-2xl md:text-3xl text-theme tracking-wide">{item}</h3>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       SECTION 3 — IMPACT MODEL  (Phases.astro pattern)
       Centered header · 2×2 bordered grid · center diamond · dot bullets
       ═══════════════════════════════════════════════════════════════ -->
  <section class="w-full py-10 md:py-32 px-6 md:px-12 bg-theme-base relative overflow-hidden transition-colors duration-500">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-brand-gold font-sans text-xs uppercase tracking-[0.3em] mb-6 block font-semibold">
          {content.impactModel.eyebrow}
        </span>
        <h2 class="font-serif text-4xl md:text-5xl text-theme mb-6">{content.impactModel.title}</h2>
      </div>

      <div class="relative max-w-5xl mx-auto border theme-card rounded-lg overflow-hidden">
        <!-- Center diamond decoration -->
        <div class="hidden md:flex absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-10 h-10 border border-brand-gold/20 bg-theme-base rotate-45 z-10 items-center justify-center transition-all duration-700 hover:border-brand-gold hover:rotate-90">
          <div class="w-2.5 h-2.5 bg-brand-gold"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2">
          {content.impactModel.items.map((item, index) => (
            <div class={`group ${index < 2 ? 'border-b' : ''} ${index % 2 === 0 ? 'md:border-e' : ''} ${index === 2 ? 'md:border-b-0' : ''} border-theme p-10 md:p-16 transition-all duration-500 hover:bg-theme-surface-strong`}>
              <div class="flex items-start gap-4">
                <span class="mt-2 w-1.5 h-1.5 bg-theme-dot rounded-full shrink-0 group-hover:bg-brand-gold transition-colors duration-500" aria-hidden="true"></span>
                <p class="font-sans text-theme-soft text-base md:text-lg leading-relaxed">{item}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       SECTION 4 — SUPPORT OPTIONS  (SupportNeeds.astro pattern)
       5/7 split · image left · numbered cards right
       ═══════════════════════════════════════════════════════════════ -->
  <section class="w-full py-10 md:py-32 px-6 md:px-12 bg-theme-base transition-colors duration-500">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">

        <!-- Left column — Header + image -->
        <div class="lg:col-span-5">
          <span class="text-brand-gold font-sans text-xs uppercase tracking-[0.3em] mb-6 block font-semibold">
            {content.supportOptions.eyebrow}
          </span>
          <h2 class="font-serif text-4xl md:text-5xl text-theme mb-8 leading-tight">
            {content.supportOptions.title}
          </h2>

          
        </div>

        <!-- Right column — Numbered cards -->
        <div class="lg:col-span-7 grid grid-cols-1 gap-6">
          {content.supportOptions.items.map((item, index) => (
            <div class="p-8 border theme-card theme-card-hover rounded-lg group hover:border-brand-gold/30 transition-all duration-500">
              <div class="flex items-start gap-6">
                <span class="font-serif text-3xl text-brand-gold/30 group-hover:text-brand-gold transition-colors duration-500 italic">{String(index + 1).padStart(2, '0')}</span>
                <p class="font-sans text-theme-soft text-base md:text-lg leading-relaxed pt-1">{item}</p>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       SECTION 5 — TRANSPARENCY  (Transparency.astro pattern)
       Reversed 7/5 split · checklist with circle checkmarks · ghost shield
       ═══════════════════════════════════════════════════════════════ -->
  <section class="w-full py-20 md:py-32 px-6 md:px-12 bg-theme-base relative overflow-hidden transition-colors duration-500">
    <div class="max-w-6xl mx-auto relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">

        <!-- Left — Checklist card (order-2 mobile, order-1 desktop) -->
        <div class="order-2 lg:order-1 lg:col-span-7 theme-card border rounded-lg p-8 md:p-12 relative">
          <!-- Ghost shield icon -->
          <div class="absolute top-0 end-0 p-4 opacity-10" aria-hidden="true">
            <svg class="w-24 h-24 text-theme" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
            </svg>
          </div>

          <div class="space-y-10">
            {content.transparencyModel.items.map((item) => (
              <div class="flex items-start gap-6 group">
                <div class="w-6 h-6 rounded-full border border-brand-gold/50 flex items-center justify-center shrink-0 mt-1 group-hover:bg-brand-gold transition-all duration-500">
                  <svg class="w-3 h-3 text-brand-gold group-hover:text-brand-dark" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
                <p class="font-sans text-theme-soft text-base md:text-lg leading-relaxed">{item}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Right — Header (order-1 mobile, order-2 desktop) -->
        <div class="order-1 lg:order-2 lg:col-span-5">
          <span class="text-brand-gold font-sans text-xs uppercase tracking-[0.3em] mb-6 block font-semibold">
            {content.transparencyModel.eyebrow}
          </span>
          <h2 class="font-serif text-4xl md:text-5xl text-theme mb-8 leading-tight">
            {content.transparencyModel.title}
          </h2>
          <div class="w-16 h-[1px] bg-brand-gold/30"></div>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       SECTION 6 — FINAL CTA  (FinalCTA.astro + WhyContinue.astro pattern)
       Ghost circle · centered dramatic layout · gold divider
       ═══════════════════════════════════════════════════════════════ -->
  <section class="w-full py-32 px-6 md:px-12 bg-theme-base relative overflow-hidden transition-colors duration-500">

    <!-- Ghost circle decoration -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] border border-brand-gold/5 rounded-full pointer-events-none" aria-hidden="true"></div>

    <div class="max-w-4xl mx-auto text-center relative z-10">
      <p class="font-serif text-2xl md:text-4xl lg:text-5xl text-theme leading-tight mb-12">
        {content.finalCta.text}
      </p>

      <!-- Gold divider -->
      <div class="w-16 h-[1px] bg-brand-gold/30 mx-auto mb-12"></div>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <a
          href={content.finalCta.primaryHref}
          target={finalPrimaryOpensInNewTab ? '_blank' : undefined}
          rel={finalPrimaryOpensInNewTab ? 'noopener noreferrer' : undefined}
          class="w-full sm:w-auto px-10 py-5 bg-brand-gold text-theme-contrast font-sans font-bold uppercase tracking-widest text-sm hover:brightness-105 transition-colors duration-300 rounded-sm"
        >
          {content.finalCta.primaryLabel}
        </a>
        <a
          href={content.finalCta.secondaryHref}
          class="w-full sm:w-auto px-10 py-5 border border-theme text-theme font-sans font-bold uppercase tracking-widest text-sm hover:border-brand-gold/70 hover:text-brand-gold transition-colors duration-300 rounded-sm"
        >
          {content.finalCta.secondaryLabel}
        </a>
      </div>
    </div>
  </section>

</MainLayout>
