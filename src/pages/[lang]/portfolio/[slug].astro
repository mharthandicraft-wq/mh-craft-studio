---
import MainLayout from '../../../layouts/MainLayout.astro';
import { render } from 'astro:content';
import { getPortfolioStaticPaths } from '../../../lib/content';
import { getTranslations, normalizeLang } from '../../../lib/i18n';

export async function getStaticPaths() {
  return getPortfolioStaticPaths();
}

const { project } = Astro.props;
const activeLang = normalizeLang(Astro.params.lang);
const t = getTranslations(activeLang);
const { Content } = await render(project);
---

<MainLayout title={project.data.title} lang={activeLang}>
  <article class="pt-32 pb-20 bg-theme-base min-h-screen transition-colors duration-500">
    <div class="max-w-6xl mx-auto px-6">
      <a href={`/${activeLang}/portfolio`} class="text-brand-gold flex items-center gap-2 mb-12 hover:opacity-70 transition-opacity">
        ← {t.ui.backToCollection}
      </a>

      <header class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-20">
        <div>
          <h1 class="font-serif text-5xl md:text-7xl text-theme mb-6 leading-tight">
            {project.data.title}
          </h1>
          <p class="text-brand-gold font-sans uppercase tracking-widest text-sm mb-4">
            {t.ui.durationLabel}: {project.data.time}
          </p>
        </div>
        <div class="flex items-end">
          <p class="text-theme-muted text-lg leading-relaxed italic border-l-2 border-brand-gold/30 pl-6">
            {project.data.description}
          </p>
        </div>
      </header>

      <div class="w-full aspect-video overflow-hidden mb-12 shadow-2xl">
        <img 
          src={project.data.mainImage} 
          alt={project.data.mainImageAlt} 
          class="w-full h-full object-cover"
        />
      </div>

      <div class="columns-1 md:columns-2 lg:columns-3 gap-6 space-y-6">
        {project.data.gallery.map((img) => (
          <div class="break-inside-avoid overflow-hidden rounded-sm group cursor-zoom-in">
            <img 
              src={img.src} 
              alt={img.alt} 
              class="w-full h-auto object-cover grayscale-[30%] group-hover:grayscale-0 transition-all duration-500 hover:scale-105"
            />
          </div>
        ))}
      </div>

      <div class="mt-20 prose prose-invert max-w-none border-t border-theme-soft pt-12 text-theme">
        <Content />
      </div>
    </div>
  </article>
</MainLayout>