---
import MainLayout from '../../../layouts/MainLayout.astro';
import { render } from 'astro:content';
import { getPortfolioStaticPaths } from '../../../lib/content';
import PortfolioLightbox from '../../../components/react/PortfolioLightbox';
import { getTranslations, normalizeLang } from '../../../lib/i18n';

export async function getStaticPaths() {
  return getPortfolioStaticPaths();
}

const { project } = Astro.props;
const activeLang = normalizeLang(Astro.params.lang);
const t = getTranslations(activeLang);
const { Content } = await render(project);
const slides = [
  { src: project.data.mainImage, alt: project.data.mainImageAlt },
  ...project.data.gallery,
];
---

<MainLayout title={project.data.title} lang={activeLang}>
  <article class="pt-32 pb-20 bg-theme-base min-h-screen transition-colors duration-500">
    <div class="max-w-6xl mx-auto px-6">
      <a href={`/${activeLang}/portfolio`} class="text-brand-gold flex items-center gap-2 mb-12 hover:opacity-70 transition-opacity">
        ← {t.ui.backToCollection}
      </a>

      <header class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-20">
        <div>
          <h1 class="font-serif text-5xl md:text-7xl text-theme mb-6 leading-tight">
            {project.data.title}
          </h1>
          <p class="text-brand-gold font-sans uppercase tracking-widest text-sm mb-4">
            {t.ui.durationLabel}: {project.data.time}
          </p>
        </div>
        <div class="flex items-end">
          <p class="text-theme-muted text-lg leading-relaxed italic border-s-2 border-brand-gold/30 ps-6">
            {project.data.description}
          </p>
        </div>
      </header>

      <PortfolioLightbox
        slides={slides}
        labels={{
          close: t.ui.closeImageViewer,
          next: t.ui.nextImage,
          previous: t.ui.previousImage,
          viewer: t.ui.openImageViewer,
          thumbnails: t.ui.galleryThumbnails,
        }}
        client:visible
      />

      <div class="mt-20 prose prose-invert max-w-none border-t border-theme-soft pt-12 text-theme">
        <Content />
      </div>
    </div>
  </article>
</MainLayout>