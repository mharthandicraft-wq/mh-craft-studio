---
import MainLayout from '../../layouts/MainLayout.astro';
import PortfolioGrid from '../../components/PortfolioGrid.tsx';
---

<MainLayout title="Portfolio" lang="en">
  <section class="pt-32 pb-20 px-6 md:px-12 bg-brand-light dark:bg-brand-dark transition-colors duration-500">
    <div class="max-w-6xl mx-auto">
      <header class="mb-20 space-y-4">
        <span class="text-brand-gold font-sans text-xs uppercase tracking-[0.4em] block font-bold">
          The Archive of Patience
        </span>
        <h1 class="font-serif text-5xl md:text-7xl text-neutral-900 dark:text-white leading-tight">
          Selected <span class="italic text-brand-gold font-light">Works</span>
        </h1>
        <p class="font-sans text-neutral-600 dark:text-neutral-400 text-lg max-w-xl">
          Every piece is a testament to thousands of years of tradition, hand-assembled triangle by triangle.
        </p>
      </header>

      <PortfolioGrid client:load />

      <footer class="mt-32 text-center border-t border-black/5 dark:border-white/5 pt-20">
        <h2 class="font-serif text-3xl text-neutral-900 dark:text-white mb-8">Have a specific project in mind?</h2>
        <a 
          href="mailto:contact@mhcraft.studio" 
          class="inline-block bg-brand-gold text-white px-10 py-4 rounded-sm font-sans uppercase tracking-widest hover:bg-neutral-900 transition-colors shadow-lg"
        >
          Start a Conversation
        </a>
      </footer>
    </div>
  </section>
</MainLayout>