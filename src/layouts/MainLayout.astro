---
// src/layouts/MainLayout.astro
import '../styles/global.css';
import Header from '../components/Header.astro';
import Navbar from '../components/Navbar.astro';

interface Props {
  title: string;
  description?: string;
  lang: string;
}

const { 
  title, 
  description = "MH Craft Studio - Traditional Persian Khatam-kari", 
  lang 
} = Astro.props;

// Calculate direction based on language
const dir = lang === 'fa' ? 'rtl' : 'ltr';
---

<!DOCTYPE html>
<html lang={lang} dir={dir} class="bg-brand-dark text-white">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | MH Craft Studio</title>
  </head>
  <body class="min-h-screen antialiased overflow-x-hidden">
    <Header />
    <Navbar />
    
    <main>
      <slot />
    </main>
  </body>
</html>